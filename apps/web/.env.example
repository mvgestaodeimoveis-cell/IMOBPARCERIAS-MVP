# URL interna do backend usada pelo BFF do Next (server-side).
# Local: http://localhost:4000 | Docker: http://api:4000 | Prod: URL do Render
BACKEND_URL=http://localhost:4000

# Contato oficial da equipe exibido nas telas de suporte (ex.: perfil rejeitado).
# NEXT_PUBLIC_CONTATO_WHATSAPP: somente dígitos com DDI (ex.: 5571999998888). Vazio = oculta o botão.
NEXT_PUBLIC_CONTATO_EMAIL=mvgestaodeimoveis@gmail.com
NEXT_PUBLIC_CONTATO_WHATSAPP=5571991541269

# Login com Google: 'true' ativa o botão (requer as credenciais Google configuradas na API).
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED=false
