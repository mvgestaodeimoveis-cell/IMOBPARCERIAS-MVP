{
  "name": "@imob/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend (API REST) do Imob Parcerias",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed:admin": "tsx src/db/seed-admin.ts",
    "seed:demo": "tsx src/db/seed-demo.ts",
    "test": "node --import tsx --test src/lib/comissao.test.ts src/lib/contrato-parceria.test.ts src/lib/parse-imovel-texto.test.ts src/lib/password.test.ts src/lib/termo-parceria.test.ts src/modules/auth/auth.schemas.test.ts src/modules/imoveis/imoveis.schemas.test.ts src/modules/parcerias/parcerias.schemas.test.ts",
    "test:db": "node --import tsx --test src/modules/parcerias/parceria-flow.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
