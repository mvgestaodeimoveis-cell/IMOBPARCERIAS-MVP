# Banco de dados (Neon) — use o branch "staging" no dev
DATABASE_URL=postgresql://user:senha@host/db?sslmode=require

# Autenticação
JWT_SECRET=troque-por-um-segredo-forte-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# URL do frontend (usada nos links de e-mail, ex.: recuperação de senha)
APP_WEB_URL=http://localhost:3000

# Termo de Uso (placeholder até o cliente enviar o texto oficial)
TERMO_VERSAO=2026-07-01

# Expiração do token de recuperação de senha
RESET_TOKEN_EXPIRES_IN=1h

# E-mail transacional (opcional no dev; sem chave, os e-mails vão para o console)
RESEND_API_KEY=
EMAIL_FROM=Imob Parcerias <no-reply@imobparcerias.com.br>
# E-mail que recebe o aviso de novo cadastro pendente (opcional; vazio = não notifica)
EQUIPE_NOTIFICACAO_EMAIL=
# Double opt-in (B4): 'true' exige e-mail confirmado para concluir o cadastro. Padrão: desligado.
EXIGIR_EMAIL_VERIFICADO=false

# Fotos dos imóveis (Cloudinary). Sem essas variáveis, o upload fica desabilitado.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Login com Google (OAuth 2.0) — opcional. Sem as três, o fluxo fica desativado.
# GOOGLE_REDIRECT_URI deve apontar para o BFF do front: https://SEU_DOMINIO/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Notificações por WhatsApp (opcional). Sem as duas, as mensagens caem no log (desativado).
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
