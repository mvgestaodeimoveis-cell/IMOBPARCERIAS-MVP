# Banco de dados (Neon) — use o branch "staging" no dev
DATABASE_URL=postgresql://user:senha@host/db?sslmode=require

# Autenticação
JWT_SECRET=troque-por-um-segredo-forte-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# URL do frontend (usada nos links de e-mail, ex.: recuperação de senha)
APP_WEB_URL=http://localhost:3000

# Termo de Uso (placeholder até o cliente enviar o texto oficial)
TERMO_VERSAO=2026-07-01

# Expiração do token de recuperação de senha
RESET_TOKEN_EXPIRES_IN=1h

# E-mail transacional (opcional no dev; sem chave, os e-mails vão para o console)
RESEND_API_KEY=
EMAIL_FROM=Imob Parcerias <no-reply@imobparcerias.com.br>
