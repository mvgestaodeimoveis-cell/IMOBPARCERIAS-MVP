# === Banco de dados (Neon) ===
DATABASE_URL=postgresql://user:senha@host/db?sslmode=require

# === Autenticação ===
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# === E-mail transacional (Resend) ===
RESEND_API_KEY=
# E-mail que recebe o aviso de novo cadastro pendente (opcional; vazio = não notifica)
EQUIPE_NOTIFICACAO_EMAIL=

# === App ===
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# === Frontend (BFF do Next repassa /api/* para o backend) ===
BACKEND_URL=http://localhost:4000
